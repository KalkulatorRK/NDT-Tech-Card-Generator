{
  "mcpServers": {
    "karta-nk-gateway": {
      "command": "python3",
      "args": ["-m", "karta_nk_gateway"],
      "cwd": "${workspaceFolder}/mcp_gateway",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/mcp_gateway"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "neon-postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${env:NEON_MCP_DATABASE_URL}"
      ]
    },
    "normative-docs": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}/ndt_web/normative_docs"
      ]
    },
    "karta-nk-project": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}/ndt_web"
      ]
    }
  }
}
