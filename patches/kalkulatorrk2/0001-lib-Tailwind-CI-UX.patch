@@ -0,0 +1,56 @@
+/**
+ * Расчёт активности радиоизотопных источников.
+ * Константы согласованы с ndt_web/normative/calculations.py (Карта-НК).
+ */
+
+export const HALF_LIFE_DAYS: Record<string, number> = {
+  'Ir-192': 73.83,
+  'Se-75': 119.78,
+  'Co-60': 1925.5,
+  'Tm-170': 128.6,
+};
+
+/** Коэффициенты пересчёта Ки → гр.-экв. радия (для таблицы активности) */
+export const CONVERSION_FACTORS: Record<string, number> = {
+  'Ir-192': 0.34,
+  'Se-75': 0.27,
+  'Co-60': 1.30,
+  'Tm-170': 0.018,
+};
+
+export type SourceType = keyof typeof HALF_LIFE_DAYS;
+
+export interface ActivityResult {
+  remainingActivityCi: number;
+  raEquivalent: number;
+  deltaDays: number;
+}
+
+/** Остаточная активность: A(t) = A₀ × 0,5^(Δt / T½) */
+export function calcRemainingActivity(
+  sourceType: SourceType,
+  initialActivityCi: number,
+  releaseDate: Date,
+  targetDate: Date,
+): ActivityResult {
+  const halfLife = HALF_LIFE_DAYS[sourceType];
+  const deltaDays = (targetDate.getTime() - releaseDate.getTime()) / (1000 * 60 * 60 * 24);
+  const remainingActivityCi = initialActivityCi * Math.pow(0.5, deltaDays / halfLife);
+  const conversion = CONVERSION_FACTORS[sourceType] ?? 1;
+  return {
+    remainingActivityCi,
+    raEquivalent: remainingActivityCi * conversion,
+    deltaDays,
+  };
+}
+
+/** Текущая активность по паспортным данным на заданную дату */
+export function calcActivityFromPassport(
+  sourceType: SourceType,
+  passportActivityCi: number,
+  passportDate: Date,
+  targetDate: Date = new Date(),
+): number {
+  return calcRemainingActivity(sourceType, passportActivityCi, passportDate, targetDate)
+    .remainingActivityCi;
+}
diff --git a/lib/scheme-calculations.ts b/lib/scheme-calculations.ts
new file mode 100644
index 0000000..f60d535
--- /dev/null
+++ b/lib/scheme-calculations.ts
@@ -0,0 +1,312 @@
+import { TABLE_DATA_5A, TABLE_DATA_5G } from './gost-tables';
+
+export interface CalculationLog {
+  steps: string[];
+  resultsData: Record<string, string | number>;
+}
+
+export function getC(focalSpotMm: number, sensitivityMm: number): number {
+  return Math.max((2 * focalSpotMm) / sensitivityMm, 4);
+}
+
+export function findClosestKey(table: Record<string, unknown>, value: number): string {
+  return Object.keys(table).reduce((prev, curr) =>
+    Math.abs(parseFloat(curr) - value) < Math.abs(parseFloat(prev) - value) ? curr : prev,
+  );
+}
+
+function safeAsinDegrees(value: number): number | null {
+  if (value < -1 || value > 1) return null;
+  return (Math.asin(value) * 180) / Math.PI;
+}
+
+export function calcScheme4_6(phi: number, s: number, k: number, log: CalculationLog) {
+  const c = getC(phi, k);
+  log.steps.push(`Расчёт коэффициента С: C = (2 * Φ) / K = (2 * ${phi}) / ${k} = ${c.toFixed(4)}`);
+  const f = c * s;
+  log.steps.push(`Расчёт фокусного расстояния f: f = C * s = ${c.toFixed(4)} * ${s} = ${f.toFixed(3)} мм`);
+  log.resultsData = { 'Коэффициент C': c, 'Расстояние f, не менее': `${f.toFixed(1)} мм` };
+  return { c, f };
+}
+
+export function calcScheme5a(phi: number, k: number, dOuter: number, dInner: number, log: CalculationLog) {
+  const m = dInner / dOuter;
+  log.steps.push(`Расчёт m: m = d / D = ${dInner} / ${dOuter} = ${m.toFixed(4)}`);
+  const c = getC(phi, k);
+  log.steps.push(`Расчёт C: C = ${c.toFixed(4)}`);
+  const f = 0.7 * c * (dOuter - dInner);
+  log.steps.push(`Расчёт f: f = 0,7 * C * (D - d) = 0,7 * ${c.toFixed(4)} * (${dOuter} - ${dInner}) = ${f.toFixed(3)} мм`);
+  const fD = f / dOuter;
+  log.steps.push(`Расчёт f/D: f/D = ${f.toFixed(3)} / ${dOuter} = ${fD.toFixed(4)}`);
+  const closestMKey = findClosestKey(TABLE_DATA_5A, m);
+  log.steps.push(`Поиск в таблице для m ≈ ${closestMKey}`);
+  const tableRow = TABLE_DATA_5A[parseFloat(closestMKey)];
+  let n = 10;
+  for (const [exposures, minFD] of Object.entries(tableRow).sort((a, b) => parseInt(a[0]) - parseInt(b[0]))) {
+    if (fD >= minFD) {
+      n = parseInt(exposures);
+      log.steps.push(`Условие f/D >= ${minFD} выполнено. Выбрано N = ${n}`);
+      break;
+    }
+  }
+  const angle = 360 / n;
+  const l = (Math.PI * dOuter) / n;
+  log.resultsData = { f: `${f.toFixed(1)} мм`, N: n, Угол: `${angle.toFixed(0)}°`, L: `${l.toFixed(0)} мм` };
+  return { c, f, n, angle, l };
+}
+
+export type Scheme5bResult =
+  | { ok: true; c: number; optimalL: number; optimalF: number; optimalN: number; optimalQ: number; usedAutoAdjustment: boolean }
+  | { ok: false; error: 'invalid_l' | 'not_found'; message: string; suggestL?: number };
+
+export function calcScheme5b(
+  phi: number,
+  k: number,
+  dOuter: number,
+  dInner: number,
+  filmLength: number,
+  log: CalculationLog,
+): Scheme5bResult {
+  const m = dInner / dOuter;
+  let currentL = filmLength;
+  log.steps.push(`Расчёт основных параметров:`);
+  log.steps.push(`  m = d / D = ${dInner} / ${dOuter} = ${m.toFixed(4)}`);
+
+  if (currentL >= dInner) {
+    log.steps.push(`Ошибка: l (${currentL} мм) ≥ d (${dInner} мм)`);
+    return {
+      ok: false,
+      error: 'invalid_l',
+      message: `Длина снимка l (${currentL} мм) должна быть меньше внутреннего диаметра d (${dInner} мм)`,
+    };
+  }
+
+  let foundSolution = false;
+  let optimalN = 0;
+  let optimalF = 0;
+  let optimalQ = 0;
+  let optimalL = filmLength;
+  let usedAutoAdjustment = false;
+
+  for (let iteration = 0; iteration < 10; iteration++) {
+    const b = currentL / dInner;
+    const c = getC(phi, k);
+    const currentF = 0.5 * c * (1 - m * Math.sqrt(1 - b * b)) * dOuter;
+
+    if (iteration === 0) {
+      log.steps.push(`  Исходные параметры: l = ${currentL.toFixed(1)} мм, b = l/d = ${b.toFixed(4)}`);
+      log.steps.push(`  C = max(2Φ/K, 4) = ${c.toFixed(4)}`);
+      log.steps.push(`  f_min = 0,5C(1 - m√(1 - b²))D = ${currentF.toFixed(1)} мм`);
+    } else {
+      log.steps.push(`\nИтерация ${iteration}: l = ${currentL.toFixed(1)} мм, b = ${b.toFixed(4)}`);
+    }
+
+    for (let n = 1; n <= 5; n++) {
+      const denominator = Math.sqrt(
+        Math.pow(2 * n + 1 - m * Math.sqrt(1 - b * b), 2) + m * m * b * b,
+      );
+      const q = (b * (2 * n + 1)) / denominator;
+      const maxQ = Math.sqrt(1 - 0.2 * Math.pow(2.6 - 1 / m, 2));
+      log.steps.push(`  Проверка для n = ${n}: q = ${q.toFixed(4)}, maxQ = ${maxQ.toFixed(4)}`);
+
+      if (q <= maxQ) {
+        const angle1 = safeAsinDegrees(q * m);
+        const angle2 = safeAsinDegrees((q * m) / (2 * n + 1));
+        if (angle1 === null || angle2 === null) {
+          log.steps.push(`  ✗ arcsin вне допустимого диапазона`);
+          continue;
+        }
+        const nVal = 180 / (angle1 - angle2);
+        const roundedN = Math.ceil(nVal);
+        log.steps.push(`  ✓ Условие выполняется! N = ${roundedN} экспозиций`);
+        optimalN = roundedN;
+        optimalF = currentF;
+        optimalQ = q;
+        optimalL = currentL;
+        foundSolution = true;
+        if (iteration > 0) {
+          usedAutoAdjustment = true;
+          log.steps.push(`  Автоматически подобрана длина снимка: ${optimalL.toFixed(1)} мм`);
+        }
+        break;
+      }
+      log.steps.push(`  ✗ Условие не выполняется: q > maxQ`);
+    }
+
+    if (foundSolution) break;
+
+    const newL = currentL * 0.9;
+    if (newL < 50) {
+      log.steps.push(`  Достигнута минимальная длина снимка (50 мм).`);
+      break;
+    }
+    log.steps.push(`  Решение не найдено. Уменьшаем l с ${currentL.toFixed(1)} до ${newL.toFixed(1)} мм`);
+    currentL = newL;
+  }
+
+  if (!foundSolution) {
+    log.steps.push(`\nРешение не найдено после всех итераций.`);
+    return {
+      ok: false,
+      error: 'not_found',
+      message: 'Для заданных параметров не удалось найти решение, удовлетворяющее условиям ГОСТ.',
+      suggestL: currentL,
+    };
+  }
+
+  const c = getC(phi, k);
+  const lSection = (Math.PI * dOuter) / optimalN;
+  log.resultsData = {
+    'Коэффициент C': c,
+    'Длина снимка l': `${optimalL.toFixed(1)} мм`,
+    'Минимальное расстояние f': `${optimalF.toFixed(1)} мм`,
+    'Экспозиций N': optimalN,
+    'Длина участка L': `${lSection.toFixed(0)} мм`,
+    'Коэффициент q': optimalQ.toFixed(4),
+    'Коэффициент b': (optimalL / dInner).toFixed(4),
+  };
+
+  return {
+    ok: true,
+    c,
+    optimalL,
+    optimalF,
+    optimalN,
+    optimalQ,
+    usedAutoAdjustment,
+  };
+}
+
+export type Scheme5zhResult =
+  | { ok: true; c: number; fMin: number; r: number; optimalN: number; angle: number; l: number; nParam: number }
+  | { ok: false; error: 'f_exceeds_d' | 'not_found'; message: string; fMin?: number; dInner?: number };
+
+export function calcScheme5zh(
+  phi: number,
+  k: number,
+  dOuter: number,
+  dInner: number,
+  log: CalculationLog,
+): Scheme5zhResult {
+  const m = dInner / dOuter;
+  const c = getC(phi, k);
+  log.steps.push(`Расчёт основных параметров:`);
+  log.steps.push(`  m = d / D = ${dInner} / ${dOuter} = ${m.toFixed(4)}`);
+  log.steps.push(`  C = max(2Φ/K, 4) = ${c.toFixed(4)}`);
+
+  const fMinRequired = 0.5 * c * (1 - m) * dOuter;
+  log.steps.push(`  Минимальное требуемое f = ${fMinRequired.toFixed(1)} мм`);
+
+  if (fMinRequired > dInner) {
+    log.steps.push(`  Условие не выполняется: f (${fMinRequired.toFixed(1)} мм) > d (${dInner} мм)`);
+    return {
+      ok: false,
+      error: 'f_exceeds_d',
+      message: `f ≥ ${fMinRequired.toFixed(1)} мм > d = ${dInner} мм`,
+      fMin: fMinRequired,
+      dInner,
+    };
+  }
+
+  const numerator = 0.25 * Math.pow(c, 2) * (1 - Math.pow(m, 2));
+  const denominator = Math.pow(m, 2) * (c + 1);
+  const r = Math.sqrt(1 - numerator / denominator);
+  log.steps.push(`  r = ${r.toFixed(4)}`);
+
+  let optimalN = Infinity;
+  let optimalNForN = 0;
+
+  for (let n = 1; n <= 5; n++) {
+    const angle1 = safeAsinDegrees(r * m);
+    const angle2 = safeAsinDegrees((r * m) / (2 * n - m));
+    if (angle1 === null || angle2 === null) continue;
+    const nVal = 180 / (angle1 + angle2);
+    const roundedN = Math.ceil(nVal);
+    log.steps.push(`    n = ${n}: N = ${roundedN} экспозиций`);
+    if (roundedN < optimalN) {
+      optimalN = roundedN;
+      optimalNForN = n;
+    }
+  }
+
+  if (optimalN === Infinity) {
+    return { ok: false, error: 'not_found', message: 'Решение не найдено для n от 1 до 5' };
+  }
+
+  const angle = 360 / optimalN;
+  const l = (Math.PI * dOuter) / optimalN;
+  log.resultsData = {
+    'Коэффициент C': c.toFixed(2),
+    'Минимальное расстояние f': `${fMinRequired.toFixed(1)} мм`,
+    'Коэффициент r': r.toFixed(4),
+    'Экспозиций N': optimalN,
+    'Угол между экспозициями': `${angle.toFixed(1)}°`,
+    'Длина участка L': `${l.toFixed(0)} мм`,
+    'Геометрический параметр n': optimalNForN,
+  };
+
+  return { ok: true, c, fMin: fMinRequired, r, optimalN, angle, l, nParam: optimalNForN };
+}
+
+export function calcScheme5v(phi: number, k: number, dOuter: number, log: CalculationLog) {
+  const c = getC(phi, k);
+  log.steps.push(`C = ${c.toFixed(4)}`);
+  const f = c * dOuter;
+  log.steps.push(`f = C * D = ${f.toFixed(3)} мм`);
+  const n = 2;
+  const angle = 180;
+  const l = (Math.PI * dOuter) / 2;
+  log.resultsData = { f: `${f.toFixed(1)} мм`, N: n, Угол: `${angle}°`, L: `${l.toFixed(0)} мм` };
+  return { c, f, n, angle, l };
+}
+
+export function calcScheme5gOr5d(
+  scheme: '5g' | '5d',
+  phi: number,
+  k: number,
+  dOuter: number,
+  dInner: number,
+  log: CalculationLog,
+): { f: number; n: number | null; angle: number; l: number; fD: number } {
+  const m = dInner / dOuter;
+  log.steps.push(`m = d / D = ${m.toFixed(4)}`);
+  const c = getC(phi, k);
+  log.steps.push(`C = ${c.toFixed(4)}`);
+  const f =
+    scheme === '5g'
+      ? 0.5 * (1.5 * c * (dOuter - dInner) - dOuter)
+      : 0.5 * (c * (1.4 * dOuter - dInner) - dOuter);
+  log.steps.push(`f (оценочно) = ${f.toFixed(3)} мм`);
+  const fD = f / dOuter;
+  log.steps.push(`f/D = ${fD.toFixed(4)}`);
+
+  const closestMKey = findClosestKey(TABLE_DATA_5G, m);
+  log.steps.push(`Поиск в таблице для m ≈ ${closestMKey}`);
+  const tableRow = TABLE_DATA_5G[parseFloat(closestMKey)];
+  let n: number | null = null;
+
+  for (const [exposures, condition] of Object.entries(tableRow).sort((a, b) => parseInt(a[0]) - parseInt(b[0]))) {
+    const [operator, threshold] = condition;
+    log.steps.push(` - Проверка для N=${exposures}: f/D (${fD.toFixed(4)}) ${operator} ${threshold}?`);
+    if (
+      (operator === '≥' && fD >= threshold) ||
+      (operator === '≤' && fD <= threshold) ||
+      (operator === '>' && fD > threshold)
+    ) {
+      n = parseInt(exposures);
+      log.steps.push(`   > Условие выполнено. N = ${n}`);
+      break;
+    }
+  }
+
+  if (n === null) {
+    log.steps.push('N не найдено.');
+    log.resultsData = { Результат: `Для m=${m.toFixed(3)} и f/D=${fD.toFixed(3)} N не найдено.` };
+    return { f, n: null, angle: 0, l: 0, fD };
+  }
+
+  const angle = 360 / n;
+  const l = (Math.PI * dOuter) / n;
+  log.resultsData = { f: `${(fD * dOuter).toFixed(1)} мм`, N: n, Угол: `${angle.toFixed(0)}°`, L: `${l.toFixed(0)} мм` };
+  return { f, n, angle, l, fD };
+}
