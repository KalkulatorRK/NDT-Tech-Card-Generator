SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Настройки базы данных (по умолчанию SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/ndt_db

# Настройки ЮKassa (платёжная система)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Email (Yandex SMTP — для подтверждения регистрации)
# Пароль: «Пароль приложения» в настройках Яндекс ID (не основной пароль!)
# Для Render рекомендуется порт 587 + TLS (ниже). Порт 465 + SSL тоже работает.
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=moohobor@yandex.ru
EMAIL_HOST_PASSWORD=вставьте-пароль-приложения-яндекс
DEFAULT_FROM_EMAIL=moohobor@yandex.ru

# URL сайта (обязательно для ссылок в письмах подтверждения)
SITE_URL=https://nk-karta.onrender.com

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_REQUIRED_SCORE=0.5
