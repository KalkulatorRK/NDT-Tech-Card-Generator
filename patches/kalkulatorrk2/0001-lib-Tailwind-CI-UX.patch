@@ -0,0 +1,59 @@
+import React, { useState } from 'react';
+import { NavLink } from 'react-router-dom';
+import { Menu, X } from 'lucide-react';
+
+const links = [
+  { to: '/', label: 'Главная' },
+  { to: '/parameters', label: 'Параметры РК' },
+  { to: '/exposure', label: 'Время экспозиции' },
+  { to: '/activity', label: 'Активность источника' },
+  { to: '/geometric-unsharpness', label: 'Геом. нерезкость' },
+  { to: '/about', label: 'О проекте' },
+];
+
+const linkClass = ({ isActive }: { isActive: boolean }) =>
+  `block px-4 py-2 rounded-md text-sm font-medium transition-colors ${
+    isActive
+      ? 'bg-blue-600 text-white'
+      : 'text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700'
+  }`;
+
+const MobileNav: React.FC = () => {
+  const [open, setOpen] = useState(false);
+
+  return (
+    <div className="md:hidden">
+      <button
+        type="button"
+        onClick={() => setOpen(!open)}
+        className="p-2 rounded-md text-slate-700 dark:text-slate-200 hover:bg-slate-200 dark:hover:bg-slate-700"
+        aria-expanded={open}
+        aria-controls="mobile-menu"
+        aria-label={open ? 'Закрыть меню' : 'Открыть меню'}
+      >
+        {open ? <X size={24} /> : <Menu size={24} />}
+      </button>
+      {open && (
+        <nav id="mobile-menu" className="absolute left-4 right-4 top-full mt-2 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 p-2 z-50 flex flex-col gap-1">
+          {links.map(({ to, label }) => (
+            <NavLink key={to} to={to} className={linkClass} onClick={() => setOpen(false)}>
+              {label}
+            </NavLink>
+          ))}
+        </nav>
+      )}
+    </div>
+  );
+};
+
+export const DesktopNav: React.FC = () => (
+  <nav className="hidden md:flex items-center gap-2" aria-label="Основная навигация">
+    {links.map(({ to, label }) => (
+      <NavLink key={to} to={to} className={linkClass}>
+        {label}
+      </NavLink>
+    ))}
+  </nav>
+);
+
+export default MobileNav;
