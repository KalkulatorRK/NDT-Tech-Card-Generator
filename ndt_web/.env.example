SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Настройки базы данных (по умолчанию SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/ndt_db

# Настройки ЮKassa (платёжная система)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# ------------------------------------------------------------------
# Почта для подтверждения регистрации (выберите ОДИН вариант)
# ------------------------------------------------------------------

# ВАРИАНТ A (рекомендуется для Render): Resend API — https://resend.com
# 1. Регистрация → API Keys → создать ключ
# 2. Domains → добавить nk-karta.ru (DNS-записи) ИЛИ для теста onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxxxxx
DEFAULT_FROM_EMAIL=onboarding@resend.dev
# При верификации домена: DEFAULT_FROM_EMAIL=noreply@nk-karta.ru

# ВАРИАНТ B (рекомендуется, проще Resend): Brevo — https://www.brevo.com
# 1. Регистрация → Senders → подтвердить email moohobor@yandex.ru
# 2. SMTP & API → SMTP → сгенерировать SMTP-ключ (НЕ пароль от Яндекса!)
# 3. На Render достаточно трёх переменных (хост подставится сам):
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxx
BREVO_LOGIN=moohobor@yandex.ru
DEFAULT_FROM_EMAIL=moohobor@yandex.ru
# Удалите на Render: EMAIL_HOST=smtp.yandex.ru и EMAIL_HOST_PASSWORD (пароль Яндекса)

# ВАРИАНТ B2: те же настройки Brevo вручную (если без BREVO_SMTP_KEY)
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=moohobor@yandex.ru
# EMAIL_HOST_PASSWORD=ваш-smtp-ключ-brevo
# DEFAULT_FROM_EMAIL=moohobor@yandex.ru

# ВАРИАНТ C: Яндекс SMTP — НЕ работает с Render (ошибка 535 access rights)
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=587
# EMAIL_HOST_USER=moohobor@yandex.ru
# EMAIL_HOST_PASSWORD=пароль-приложения-яндекс

EMAIL_TIMEOUT=10

# URL сайта (обязательно для ссылок в письмах подтверждения)
SITE_URL=https://nk-karta.onrender.com

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_REQUIRED_SCORE=0.5
