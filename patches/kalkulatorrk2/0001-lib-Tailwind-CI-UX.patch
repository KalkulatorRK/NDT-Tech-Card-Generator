+/** Расчёт геометрической нерезкости по ГОСТ 7512-82 */
+
+export const GOST_7512_REFERENCE = 'ГОСТ 7512-82';
+
+export function calcGeometricUnsharpness(
+  focusSizeMm: number,
+  objectToDetectorMm: number,
+  focusDistanceMm: number,
+): number | null {
+  if (focusDistanceMm <= objectToDetectorMm) return null;
+  return (focusSizeMm * objectToDetectorMm) / (focusDistanceMm - objectToDetectorMm);
+}
+
+export function maxAllowedUnsharpness(sensitivityMm: number): number {
+  return sensitivityMm <= 2 ? sensitivityMm / 2 : 1.0;
+}
+
+export function checkGostCompliance(unsharpnessMm: number, sensitivityMm: number): boolean {
+  return unsharpnessMm <= maxAllowedUnsharpness(sensitivityMm);
+}
