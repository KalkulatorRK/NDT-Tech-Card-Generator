+      `t₁ = t₀ × ω₁ = ${baseExposure.toFixed(3)} × ${filmFactor} = ${(baseExposure * filmFactor).toFixed(3)} мин\n`;
+  }
+
+  const adjustedExposure = baseExposure * filmFactor;
+  const { finalExposureMin, log: logWithFocus } = appendFocusCorrection(
+    log,
+    PULSE_NOMOGRAM_FILMS.has(filmType) ? 2 : 3,
+    config.baseFocus,
+    focusDistance,
+    adjustedExposure,
+    'мин',
+  );
+  const finalTime = finalExposureMin * 60;
+  return {
+    finalTime,
+    log: logWithFocus + `3. Перевод в секунды:\nt_сек = t × 60 = ${finalExposureMin.toFixed(3)} × 60 = ${finalTime.toFixed(0)} сек`,
