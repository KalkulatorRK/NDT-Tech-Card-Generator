# Секреты для MCP в Cursor (локально, НЕ на Render)
# Скопируйте: cp .env.mcp.example .env.mcp
# Загрузите в shell перед запуском Cursor или добавьте в ~/.zshrc / ~/.bashrc

# GitHub: https://github.com/settings/tokens
# Репозиторий: KalkulatorRK/NDT-Tech-Card-Generator
GITHUB_TOKEN=

# Neon Direct URL (НЕ pooled -pooler)
# Console → Connection Details → Direct → скопировать строку
NEON_MCP_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Опционально: каталог для PDF с pravo.gov.ru (по умолчанию ndt_web/normative_docs)
# KARTA_NK_NORMATIVE_DOCS=/absolute/path/to/ndt_web/normative_docs
