+    `Материал: ${getMaterialName(material)}\n` +
+    `Тип плёнки: ${filmType}\n` +
+    `Радиационная толщина: ${thickness} мм\n` +
+    `Фокусное расстояние F: ${focusDistance} мм\n\n`;
+
+  if (PULSE_NOMOGRAM_FILMS.has(filmType)) {
+    baseExposure = interpolateFromPulseNomogram(config.nomogram, filmType, thickness);
+    log += `1. Базовое время из номограммы ${apparatusType} (F₀=${config.baseFocus} мм) для ${filmType}: t₀ = ${baseExposure.toFixed(3)} мин\n`;
+  } else {
+    baseExposure = interpolateFromPulseNomogram(config.nomogram, 'D7', thickness);
+    filmFactor = filmFactors.pulse[filmType] ?? 1.0;
