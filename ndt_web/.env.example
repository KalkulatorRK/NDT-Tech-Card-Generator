SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Настройки базы данных (по умолчанию SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/ndt_db

# Настройки ЮKassa (платёжная система)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# ------------------------------------------------------------------
# Почта для подтверждения регистрации (выберите ОДИН вариант)
# ------------------------------------------------------------------

# ВАРИАНТ A (рекомендуется для РФ): Unisender Go — https://go.unisender.ru
# Транзакционная почта, работает в России, интеграция через django-anymail.
# 1. Регистрация → подтвердить СВОЙ домен (не utbniti.ru — это ящик Яндекса!)
# 2. Учётная запись → Безопасность → API-ключ
# 3. URL: go1.unisender.ru → go1.../api/v1/ ; go2 → go2.../api/v1/
UNISENDER_GO_API_KEY=ваш-api-ключ
UNISENDER_GO_API_URL=https://go1.unisender.ru/ru/transactional/api/v1/
DEFAULT_FROM_EMAIL=noreply@ваш-домен.ru
SITE_URL=https://nk-karta.onrender.com

# ВАРИАНТ B: Resend — https://resend.com (нужен СВОЙ домен, utbniti.ru не подойдёт)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=noreply@nk-karta.ru

# ВАРИАНТ C: Brevo — часто недоступен в РФ (оплата, регистрация)
# BREVO_SMTP_KEY=xsmtpsib-xxxxxxxx
# BREVO_LOGIN=moohobor@yandex.ru

# ВАРИАНТ D: Яндекс SMTP — НЕ работает с Render (ошибка 535)
# EMAIL_HOST=smtp.yandex.ru

EMAIL_TIMEOUT=10

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
RECAPTCHA_REQUIRED_SCORE=0.5
