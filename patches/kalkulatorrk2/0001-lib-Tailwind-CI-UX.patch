+export function interpolateLinear(data: number[], thickness: number): number {
+  for (let i = 0; i < data.length - 1; i += 2) {
+    if (thickness === data[i]) return data[i + 1];
+  }
+  for (let i = 0; i < data.length - 2; i += 2) {
+    const t1 = data[i];
+    const e1 = data[i + 1];
+    const t2 = data[i + 2];
+    const e2 = data[i + 3];
+    if (thickness >= t1 && thickness <= t2) {
+      return e1 + ((thickness - t1) / (t2 - t1)) * (e2 - e1);
+    }
+  }
+  return thickness < data[0] ? data[1] : data[data.length - 1];
+}
+
+export function interpolateFromPulseNomogram(
+  nomogramData: Record<string, number[]>,
+  filmType: string,
+  thickness: number,
+): number {
+  if (!nomogramData[filmType]) return 1.0;
+  const data = nomogramData[filmType];
+  if (thickness < data[0]) return data[1];
+  if (thickness > data[data.length - 2]) return data[data.length - 1];
+  return interpolateLinear(data, thickness);
+}
+
+export function calculateExposureFactor(h: number, F: number): { value: number; calculation: string } {
+  const { h: hValues, F: fValues, values } = table7Data;
+  const exactHIndex = hValues.findIndex((val) => val === h);
+  const exactFIndex = fValues.findIndex((val) => val === F);
+  if (exactHIndex !== -1 && exactFIndex !== -1) {
+    const exactValue = values[exactHIndex][exactFIndex];
+    return { value: exactValue, calculation: `Точное совпадение: h=${h} мм, F=${F} мм → T=${exactValue}` };
+  }
+
+  const findIdx = (val: number, arr: number[]) => {
+    if (val <= arr[0]) return { i1: 0, i2: 1 };
+    if (val >= arr[arr.length - 1]) return { i1: arr.length - 2, i2: arr.length - 1 };
+    for (let i = 0; i < arr.length - 1; i++) {
+      if (val >= arr[i] && val <= arr[i + 1]) return { i1: i, i2: i + 1 };
+    }
+    return { i1: arr.length - 2, i2: arr.length - 1 };
+  };
+
+  const { i1: hI1, i2: hI2 } = findIdx(h, hValues);
+  const { i1: fI1, i2: fI2 } = findIdx(F, fValues);
+  const t11 = values[hI1][fI1];
+  const t12 = values[hI1][fI2];
+  const t21 = values[hI2][fI1];
+  const t22 = values[hI2][fI2];
+  const h1F = fI1 === fI2 ? t11 : t11 + ((t12 - t11) * (F - fValues[fI1])) / (fValues[fI2] - fValues[fI1]);
+  const h2F = fI1 === fI2 ? t21 : t21 + ((t22 - t21) * (F - fValues[fI1])) / (fValues[fI2] - fValues[fI1]);
+  const finalValue = hI1 === hI2 ? h1F : h1F + ((h2F - h1F) * (h - hValues[hI1])) / (hValues[hI2] - hValues[hI1]);
+  return {
+    value: finalValue,
+    calculation: `Билинейная интерполяция: T = ${finalValue.toFixed(2)}`,
+  };
+}
+
+export function getMaterialCoefficient(material: string): number {
+  switch (material) {
+    case 'steel':
+      return 1.0;
+    case 'aluminum':
+      return 0.3;
+    case 'titanium':
+      return 0.7;
+    default:
+      return 1.0;
+  }
+}
+
+export function getMaterialName(material: string): string {
+  return ({ steel: 'сталь', aluminum: 'алюминий', titanium: 'титан' } as Record<string, string>)[material] || material;
+}
+
+export function calcIsotopeExposureSeconds(
+  sourceType: SourceType,
+  activityCi: number,
+  thicknessMm: number,
+  focusDistanceMm: number,
+  material: string,
+  filmType: string,
+): { seconds: number; log: string } {
+  const tFactor = calculateExposureFactor(thicknessMm, focusDistanceMm);
+  const materialCoeff = getMaterialCoefficient(material);
+  const filmFactor = filmFactors[sourceType]?.[filmType] ?? 1.0;
+  const seconds = (tFactor.value * materialCoeff * 60 * filmFactor) / activityCi;
+  const log =
+    `T = ${tFactor.value.toFixed(2)}, K_м = ${materialCoeff}, ω₁ = ${filmFactor}, A = ${activityCi.toFixed(4)} Ки\n` +
+    `R = (${tFactor.value.toFixed(2)} × ${materialCoeff} / ${activityCi.toFixed(4)}) × 60 × ${filmFactor} = ${seconds.toFixed(0)} сек`;
+  return { seconds, log };
+}
+
+export function calcPassportActivity(
+  sourceType: SourceType,
+  passportActivity: number,
+  passportDate: Date,
+): number {
+  return calcActivityFromPassport(sourceType, passportActivity, passportDate);
+}
